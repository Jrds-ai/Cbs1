rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in ['jsteffes@gmail.com', 'jsteffes+1@gmail.com'];
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /books/{bookId} {
      allow read: if true;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Notifications: users can read/write their own; admins can write to any (via client with admin uid)
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Prompts: admins can read/write any prompt
    match /prompts/{promptId} {
      allow read, write: if isAdmin();
    }

    // Settings: anyone can read, only admins can write
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
